# Base mainnet JSON-RPC (any provider; see architecture spec "RPC provider swap")
PONDER_RPC_URL_8453=https://mainnet.base.org

# Postgres (docker compose default)
DATABASE_URL=postgresql://observatory:observatory@localhost:5439/observatory

# apps/api HTTP port (3000 is reserved for apps/web)
# PORT=3001

# apps/web -> apps/api base URL (server-side fetch; defaults to http://localhost:3001)
API_URL=http://localhost:3001
