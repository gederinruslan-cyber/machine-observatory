{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // NestJS relies on decorator metadata for DI; CommonJS is fine for Nest.
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "sourceMap": true,
    "types": ["node"]
  },
  // Tests are typechecked/linted but excluded from `nest build` (tsconfig.build.json).
  "include": ["src", "test"]
}
